{
  "form_name": "ris_form",
  "table_identifier": "items",
  "fields":{
    "ris_fund_cluster": {
      "type": "text",
      "label": "Fund Cluster:",
      "rules": {
        "required": true,
        "string": true,
        "min_length": 1,
        "max_length": 50
      }
    },
    "ris_no": {
      "type": "text",
      "label": "RIS Number:",
      "rules": {
        "required": true,
        "string": true,
        "min_length": 2,
        "max_length": 50
      }
    },
    "ris_center_code": {
      "type": "text",
      "label": "Responsibility Center Code:",
      "rules": {
        "required": true,
        "string": true,
        "min_length": 1,
        "max_length": 50
      }
    },
    "ris_received_date": {
      "type": "text",
      "label": "Date:",
      "rules": {
        "required": true,
        "date": true
      }
    }
  },
  "columns": {
    "items[{{ $index }}][ris_stock_no]": {
      "type": "text",
      "header_text": "Stock No.",
      "rules": {
        "required": false,
        "string": true,
        "min_length": 1,
        "max_length": 20
      }
    },
    "items[{{ $index }}][ris_unit]": {
      "type": "text",
      "header_text": "Unit",
      "rules": {
        "required": true,
        "string": true,
        "min_length": 5,
        "max_length": 20
      }
    },
    "items[{{ $index }}][ris_items_descrip]": {
      "type": "text",
      "header_text": "Description",
      "rules": {
        "required": true,
        "string": true,
        "min_length": 2,
        "max_length": 50
      }
    },
    "items[{{ $index }}][ris_quantity]": {
      "type": "number",
      "header_text": "Qty.",
      "rules": {
        "required": true,
        "integer": true,
        "min": 1,
        "max": 9999999
      }
    },
    "items[{{ $index }}][ris_stock_available]": {
      "type": "radio",
      "header_text": "Yes",
      "rules": {
        "required": false,
        "boolean": true
      }
    },
    "items[{{ $index }}][ris_stock_available]": {
      "type": "radio",
      "header_text": "No",
      "rules": {
        "required": false,
        "boolean": true
      }
    },
    "items[{{ $index }}][ris_issued_quantity]": {
      "type": "number",
      "header_text": "Qty.",
      "rules": {
        "required": true,
        "integer": true,
        "min": 1,
        "max": 9999999
      }
    },
    "items[{{ $index }}][ris_issued_remarks]": {
      "type": "text",
      "header_text": "Remarks",
      "rules": {
        "required": false,
        "string": true,
        "max_length": 50
      }
    }
  }
}
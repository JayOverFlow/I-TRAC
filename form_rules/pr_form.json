{
  "form_name": "pr_form",
  "table_identifier": "items",
  "fields":{
    "proj_title": {
      "type": "pr_section",
      "label": "Section:",
      "rules": {
        "required": true,
        "string": true,
        "min_length": 5,
        "max_length": 50
      }
    },
    "pr_purpose": {
      "type": "text",
      "label": "Purpose:",
      "rules": {
        "required": true,
        "string": true,
        "min_length": 5,
        "max_length": 50
      }
    },
    "pr_no": {
      "type": "text",
      "label": "P.R No.:",
      "rules": {
        "required": false,
        "string": true,
        "min_length": 5,
        "max_length": 50
      }
    }
  },
  "columns": {
    "items[{{ $rowIndex }}][unit]": {
      "type": "text",
      "header_text": "Unit",
      "rules": {
        "required": true,
        "string": true,
        "min_length": 1,
        "max_length": 20
      }
    },
    "items[{{ $rowIndex }}][description]": {
      "type": "text",
      "header_text": "Item Description",
      "rules": {
        "required": true,
        "string": true,
        "min_length": 5,
        "max_length": 50
      }
    },
    "items[{{ $rowIndex }}][quantity]": {
      "type": "number",
      "header_text": "Qty.",
      "rules": {
        "required": true,
        "integer": true,
        "min": 1,
        "max": 9999999
      }
    },
    "items[{{ $rowIndex }}][cost]": {
      "type": "number",
      "header_text": "Unit Cost",
      "rules": {
        "required": true,
        "numeric": true,
        "min": 1,
        "max": 9999999
      }
    },
    "items[{{ $rowIndex }}][specification]": {
      "type": "textarea",
      "label": "Specification",
      "rules": {
        "required": false,
        "string": true,
        "min_length": 5,
        "max_length": 1000
      }
    }
  }
}
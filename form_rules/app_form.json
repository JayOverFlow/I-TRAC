{
  "form_name": "app_form",
  "fields": {
    "proj_title": {
      "type": "text",
      "label": "Project Title",
      "rules": {
        "required": true,
        "string": true,
        "min_length": 5,
        "max_length": 50
      }
    },
    "end_user": {
      "type": "text",
      "label": "End-User or Implementing Unit",
      "rules": {
        "required": false,
        "string": true,
        "min_length": 5,
        "max_length": 50
      }
    },
    "gen_desc": {
      "type": "text",
      "label": "General Description",
      "rules": {
        "required": false,
        "string": true,
        "min_length": 5,
        "max_length": 50
      }
    },
    "mode": {
      "type": "text",
      "label": "Mode of Procurement",
      "rules": {
        "required": false,
        "string": true,
        "min_length": 5,
        "max_length": 50
      }
    },
    "criteria": {
      "type": "text",
      "label": "Criteria for Bid Evaluation",
      "rules": {
        "required": false,
        "string": true,
        "min_length": 2,
        "max_length": 50
      }
    },
    "covered": {
      "type": "radio",
      "label": "To be covered by an Early Procurement Activity",
      "options": ["Yes", "No"],
      "rules": {
        "required": true,
        "in": ["Yes", "No"]
      }
    },
    "start": {
      "type": "text",
      "label": "Start of Procurement Activity",
      "rules": {
        "required": true,
        "date": true
      }
    },
    "end": {
      "type": "text",
      "label": "End of Procurement Activity",
      "rules": {
        "required": true,
        "date": true
      }
    },
    "source": {
      "type": "text",
      "label": "Source of Fund",
      "rules": {
        "required": false,
        "string": true,
        "min_length": 2,
        "max_length": 50
      }
    },
    "esti_budget": {
      "type": "number",
      "label": "Estimated Budget/Approved Budget",
      "rules": {
        "required": false,
        "numeric": true,
        "min": 1,
        "max": 9999999999
      }
    },
    "tools": {
      "type": "text",
      "label": "Procurement Strategy or Tools",
      "rules": {
        "required": false,
        "string": true,
        "min_length": 5,
        "max_length": 50
      }
    },
    "remarks": {
      "type": "text",
      "label": "REMARKS",
      "rules": {
        "required": false,
        "string": true,
        "min_length": 5,
        "max_length": 50
      }
    }
  }
}
{
  "form_name": "rsmi_form",
  "table_identifier": "items",
  "fields":{
    "rsmi_fund_cluster": {
      "type": "text",
      "label": "Fund Cluster:",
      "rules": {
        "required": true,
        "string": true,
        "min_length": 1,
        "max_length": 50
      }
    },
    "rsmi_serial_no": {
      "type": "text",
      "label": "Serial No.:",
      "rules": {
        "required": true,
        "string": true,
        "min_length": 2,
        "max_length": 50
      }
    },
    "rsmi_date": {
      "type": "text",
      "label": "Date:",
      "rules": {
        "required": true,
        "date": true
      }
    }
  },
  "columns": {
    "items[{{ $index }}][rsmi_ris_no]": {
      "type": "text",
      "header_text": "RIS No.",
      "rules": {
        "required": true,
        "string": true,
        "min_length": 1,
        "max_length": 20
      }
    },
    "items[{{ $index }}][rsmi_center_code]": {
      "type": "text",
      "header_text": "Responsibility Center Code",
      "rules": {
        "required": true,
        "string": true,
        "min_length": 1,
        "max_length": 20
      }
    },
    "items[{{ $index }}][rsmi_stock_no]": {
      "type": "text",
      "header_text": "Stock No.",
      "rules": {
        "required": false,
        "string": true,
        "min_length": 1,
        "max_length": 20
      }
    },
    "items[{{ $index }}][rsmi_items_descrip]": {
      "type": "text",
      "header_text": "Item Description",
      "rules": {
        "required": true,
        "string": true,
        "min_length": 5,
        "max_length": 50
      }
    },
    "items[{{ $index }}][rsmi_unit]": {
      "type": "text",
      "header_text": "Unit",
      "rules": {
        "required": true,
        "string": true,
        "min_length": 1,
        "max_length": 20
      }
    },
    "items[{{ $index }}][rsmi_quantity]": {
      "type": "number",
      "header_text": "Qty. Issued",
      "rules": {
        "required": true,
        "integer": true,
        "min": 1,
        "max": 9999999
      }
    },
    "items[{{ $index }}][rsmi_unit_cost]": {
      "type": "number",
      "header_text": "Unit Cost",
      "rules": {
        "required": true,
        "integer": true,
        "min": 1,
        "max": 9999999
      }
    }
  }
}
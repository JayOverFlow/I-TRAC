{
  "form_name": "ics_form",
  "table_identifier": "items",
  "fields":{
    "ics_fund_cluster": {
      "type": "text",
      "label": "Fund Cluster:",
      "rules": {
        "required": true,
        "string": true,
        "min_length": 1,
        "max_length": 50
      }
    },
    "ics_no": {
      "type": "text",
      "label": "ICS No.:",
      "rules": {
        "required": true,
        "string": true,
        "min_length": 2,
        "max_length": 50
      }
    },
    "ics_code_no": {
      "type": "text",
      "label": "Code No:",
      "rules": {
        "required": true,
        "string": true,
        "min_length": 1,
        "max_length": 50
      }
    },
    "ics_received_from_date": {
      "type": "text",
      "label": "Date:",
      "rules": {
        "required": true,
        "date": true
      }
    },
    "ics_received_by_date": {
      "type": "text",
      "label": "Date:",
      "rules": {
        "required": true,
        "date": true
      }
    }
  },
  "columns": {
    "items[{{ $index }}][ics_quantity]": {
      "type": "number",
      "header_text": "Qty.",
      "rules": {
        "required": true,
        "integer": true,
        "min": 1,
        "max": 9999999
      }
    },
    "items[{{ $index }}][ics_unit]": {
      "type": "text",
      "header_text": "Unit",
      "rules": {
        "required": true,
        "string": true,
        "min_length": 5,
        "max_length": 20
      }
    },
    "items[{{ $index }}][ics_unit_cost]": {
      "type": "numeric",
      "header_text": "Unit Cost",
      "rules": {
        "required": true,
        "integer": true,
        "min": 1,
        "max": 9999999
      }
    },
    "items[{{ $index }}][ics_items_descrip]": {
      "type": "text",
      "header_text": "Description",
      "rules": {
        "required": true,
        "string": true,
        "min_length": 5,
        "max_length": 50
      }
    },
    "items[{{ $index }}][ics_inventory_item_no]": {
      "type": "text",
      "header_text": "Inventory Item No.",
      "rules": {
        "required": true,
        "string": true,
        "min_length": 2,
        "max_length": 20
      }
    },
    "items[{{ $index }}][ics_estimated_useful_life]": {
      "type": "text",
      "header_text": "Estimated Useful Time",
      "rules": {
        "required": false,
        "string": true,
        "min_length": 2,
        "max_length": 20
      }
    }
  }
}
  "known_issues": [
    {
      "id": "ISSUE-001",
      "severity": "medium",
      "location": "Columns F and G (Stock Available? Yes / No)",
      "description": "Both F and G share the same logical source field `ris_stock_available`. The template uses column position (F = Yes, G = No) rather than a boolean value to encode availability. An AI agent must split the boolean into two separate write targets instead of writing to a single cell.",
      "recommendation": "When injecting, evaluate the boolean: if true write 'X' to column F and leave G blank; if false leave F blank and write 'X' to G."
    },
    {
      "id": "ISSUE-002",
      "severity": "low",
      "location": "C:D column (Description) throughout item table",
      "description": "Every Description cell is a C:D horizontal merge. Agents must write to the anchor cell C{row}; writing to D{row} on a merged cell will raise an openpyxl error.",
      "recommendation": "Always target the left-most cell of a merge range (e.g., C12, not D12)."
    },
    {
      "id": "ISSUE-003",
      "severity": "low",
      "location": "ris_approved_by (D59) and Designation (D60)",
      "description": "The blank RIS sheet pre-fills 'GLENN N. ORTIZ, PECE, ASEAN ENGR.' and 'CAO / ADAF' as hard-coded values. The mapping sheet lists `ris_approved_by` as a placeholder, implying it could be overridden, but in practice it is institutional-static for this form version.",
      "recommendation": "Treat D59 and D60 as static unless a dynamic approver override is explicitly required."
    },
    {
      "id": "ISSUE-004",
      "severity": "low",
      "location": "Issued by – Designation (E60:G60)",
      "description": "'AOV - Supply Office' is hardcoded in the blank template but listed as a placeholder in the mapping sheet. Same static-vs-dynamic ambiguity as ISSUE-003.",
      "recommendation": "Treat as static unless overridden."
    },
    {
      "id": "ISSUE-005",
      "severity": "informational",
      "location": "Rows 65–8615 (beyond the form layout)",
      "description": "The workbook contains hundreds of rows with residual row-height formatting artifacts (height=13.7 or 19.5). These are carry-over formatting from the source document and do not represent additional form content.",
      "recommendation": "Ignore all rows beyond row 61 when parsing or writing data."
    }
  ],


    "item_table": {
      "description": "Repeatable line-item table for requisitioned and issued stock. One row = one item.",
      "type": "repeatable_table",
      "range": "A12:I54",
      "header_row": 11,
      "data_rows_start": 12,
      "data_rows_end": 54,
      "max_rows": 43,
      "header_group_row": 10,
      "header_groups": {
        "A10:E10": { "label": "Requisition", "merged": true },
        "F10:G10": { "label": "Stock Available?", "merged": true },
        "H10:I10": { "label": "Issue", "merged": true }
      },
      "columns": {
        "A": {
          "header": "Stock No.",
          "placeholder": "ris_stock_no",
          "data_type": "string",
          "example": "STO-2024-00123",
          "notes": "Inventory stock number from the supply catalogue."
        },
        "B": {
          "header": "Unit",
          "placeholder": "ris_unit",
          "data_type": "string",
          "example": "pc",
          "notes": "Unit of measure (e.g. pc, ream, box, set, liter)."
        },
        "C_D": {
          "header": "Description",
          "placeholder": "ris_items_descrip + ris_spec_description",
          "cell_range": "C:D",
          "merged_per_row": true,
          "merge_pattern": "C{n}:D{n}",
          "data_type": "string",
          "composition": "Primary item description followed by optional specification detail, separated by a comma or newline.",
          "sub_fields": {
            "ris_items_descrip": {
              "description": "Short item name / catalogue description.",
              "data_type": "string",
              "example": "Bond Paper, Short"
            },
            "ris_spec_description": {
              "description": "Additional specification or brand qualifier (optional).",
              "data_type": "string",
              "example": "sub-20, 8.5x11, white"
            }
          },
          "example": "Bond Paper, Short, sub-20, 8.5x11, white"
        },
        "E": {
          "header": "Qty. (Requisition)",
          "placeholder": "ris_quantity",
          "data_type": "integer",
          "example": 10,
          "notes": "Quantity requested by the requisitioning unit."
        },
        "F": {
          "header": "Yes (Stock Available?)",
          "placeholder": "ris_stock_available",
          "data_type": "string",
          "allowed_values": ["X", ""],
          "condition": "Mark 'X' when stock is available.",
          "example": "X",
          "notes": "Mutually exclusive with column G. Only one of F or G should be 'X' per row."
        },
        "G": {
          "header": "No (Stock Available?)",
          "placeholder": "ris_stock_available",
          "data_type": "string",
          "allowed_values": ["X", ""],
          "condition": "Mark 'X' when stock is NOT available.",
          "example": "",
          "notes": "Mutually exclusive with column F. Shares the same source field; value placement (F vs G) is determined by availability status."
        },
        "H": {
          "header": "Qty. (Issue)",
          "placeholder": "ris_issued_quantity",
          "data_type": "integer",
          "example": 8,
          "notes": "Actual quantity issued by the supply office. May differ from ris_quantity."
        },
        "I": {
          "header": "Remarks",
          "placeholder": "ris_issued_remarks",
          "data_type": "string",
          "example": "2 pcs on back-order",
          "notes": "Free-text remarks from the issuing officer."
        }
      },
      "merged_cell_pattern_per_row": {
        "description": "Each data row (rows 12–54) repeats the same C:D column merge.",
        "pattern": "C{row}:D{row}",
        "example_merges": ["C12:D12", "C13:D13", "C14:D14"]
      }
    },

    "purpose_field": {
      "description": "Single free-text field stating the purpose of the requisition, placed below the item table.",
      "type": "field_mapped",

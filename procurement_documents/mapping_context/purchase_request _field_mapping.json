{
  "meta": {
    "template_file": "Purchase_Request_Excel_Template__2_.xlsx",
    "sheet_name": "CHEM_1",
    "version": "1.0",
    "export_format": "pdf",
    "orientation": "portrait",
    "paper_size": "A4",
    "print_area": "A1:G54",
    "total_rows": 54,
    "total_columns": 7,
    "columns": {
      "A": { "role": "Quantity / Section Labels",           "width": 10.28 },
      "B": { "role": "Unit / Requestor Name 1",             "width": 9.85  },
      "C": { "role": "Item Description (left half)",        "width": 29.28 },
      "D": { "role": "Item Description (right half)",       "width": 29.14 },
      "E": { "role": "Unit Cost (left half) / Static Info", "width": 10.71 },
      "F": { "role": "Unit Cost (right half)",              "width": 6.14  },
      "G": { "role": "Total Cost / Campus Director Info",   "width": 19.85 }
    },
    "notes": [
      "Item Description per row uses a C:D merge — always write the value to column C (top-left of merge).",
      "Unit Cost per row uses an E:F merge — always write the value to column E (top-left of merge).",
      "Total Cost column G has NO pre-loaded formulas in the template. Inject =A{row}*E{row} for each populated item row.",
      "Grand Total cell F48:G48 is merged and has NO pre-loaded formula. Inject =SUM(G12:G47) after filling items.",
      "Never write to any cell marked readonly:true — these contain static labels or institution-fixed values."
    ]
  },

  "sections": [
    {
      "section_id": "institutional_header",
      "label": "Institutional Header",
      "row_start": 1,
      "row_end": 5,
      "repeatable": false,
      "readonly": true,
      "description": "Static TUP branding block. Contains the university logo area (A1), university name, address, website, and the PROCUREMENT OFFICE / PURCHASE REQUEST title block. Never write to any cell in this section.",
      "key_merges": [
        { "range": "B2:D2", "content": "Republic of the Philippines" },
        { "range": "E2:G2", "content": "PROCUREMENT OFFICE" },
        { "range": "B3:D3", "content": "TECHNOLOGICAL UNIVERSITY OF THE PHLIPPINES" },
        { "range": "E3:G4", "content": "PURCHASE REQUEST (spans 2 rows)" },
        { "range": "B4:D4", "content": "Km.14 East Service Road, Western Bicutan, Taguig City 1630" },
        { "range": "B5:D5", "content": "http:www.tup.edu.ph | Telephone Nos.: (632) 8824-7250 to 54 local 113" },
        { "range": "E5:G5", "content": "FM-PR-007   REV01   11MARCH2025" }
      ]
    },
    {
      "section_id": "form_info",
      "label": "Form Information",
      "row_start": 8,
      "row_end": 9,
      "repeatable": false,
      "readonly": false,
      "description": "Four INPUT fields: Department, PR Number, Section, and Date. Labels are in columns A and E; input values go in the merged cells beside them.",
      "key_merges": [
        { "range": "B8:D8", "role": "INPUT — Department value" },
        { "range": "F8:G8", "role": "INPUT — PR Number value" },
        { "range": "B9:D9", "role": "INPUT — Section value" },
        { "range": "F9:G9", "role": "INPUT — Date value" }
      ]
    },
    {
      "section_id": "table_header",
      "label": "Items Table Column Headers",
      "row_start": 10,
      "row_end": 11,
      "repeatable": false,
      "readonly": true,
      "description": "Row 10 is a full-width merged divider (A10:G10). Row 11 contains the column header labels: Quantity (A11), Unit (B11), Item Description (C11:D11 merged), Unit Cost (E11:F11 merged), Total Cost (G11). Never write to these rows.",
      "key_merges": [
        { "range": "A10:G10", "content": "Full-width horizontal divider line" },
        { "range": "C11:D11", "content": "Item Description column header" },
        { "range": "E11:F11", "content": "Unit Cost column header" }
      ]
    },
    {
      "section_id": "items_table",
      "label": "Item List",
      "row_start": 12,
      "row_end": 47,
      "repeatable": true,
      "readonly": false,
      "row_template": 12,
      "max_rows": 36,
      "description": "The main repeating section. 36 available item slots (rows 12 to 47). Every row has the same structure: A=Quantity, B=Unit, C:D merged=Item Description, E:F merged=Unit Cost, G=Total Cost (formula to be injected). Leave unfilled rows completely blank.",
      "per_row_merges": [
        { "range": "C{row}:D{row}", "role": "Item Description — write to C{row}" },
        { "range": "E{row}:F{row}", "role": "Unit Cost — write to E{row}" }
      ]
    },
    {
      "section_id": "total_row",
      "label": "Grand Total",
      "row_start": 48,
      "row_end": 48,
      "repeatable": false,
      "readonly": true,
      "description": "Row 48. A48:E48 is merged with the static label 'TOTAL'. F48:G48 is merged and holds the grand total formula. Inject =SUM(G12:G47) into F48 if the formula is not pre-loaded. Never overwrite A48:E48.",
      "key_merges": [
        { "range": "A48:E48", "content": "'TOTAL' label — static, readonly" },
        { "range": "F48:G48", "role": "Grand Total formula cell — inject =SUM(G12:G47)" }
      ]
    },
    {
      "section_id": "spacer_row",
      "label": "Blank Spacer",
      "row_start": 44,
      "row_end": 44,
      "repeatable": false,
      "readonly": true,
      "description": "Row 44 is a blank visual spacer between the TOTAL row and the footer. It has C:D and E:F merges from the template but contains no data. Do not write to this row."
    },
    {
      "section_id": "footer",
      "label": "Footer — Purpose, Signature, Requestor, Designation",
      "row_start": 50,
      "row_end": 53,
      "repeatable": false,
      "readonly": false,
      "description": "Four footer rows: PURPOSE (row 50), SIGNATURE (row 51), NAME OF REQUESTOR (row 52), DESIGNATION (row 53). E52:G52 and E53:G53 contain static Campus Director info — never overwrite those.",
      "key_merges": [
        { "range": "A50:B50", "content": "'PURPOSE:' label — static" },
        { "range": "C50:G50", "role": "INPUT — Purpose text value" },
        { "range": "A51:B51", "content": "'SIGNATURE:' label — static" },
        { "range": "C51:D51", "role": "Signature area — left blank for physical signature" },
        { "range": "E51:G51", "content": "'Approved by:' label — static" },
        { "range": "E52:G52", "content": "STATIC — 'Engr. REXMELLE F. DECAPIA, JR. Ph.D.' — DO NOT OVERWRITE" },
        { "range": "A53:B53", "content": "'DESIGNATION:' label — static" },
        { "range": "E53:G53", "content": "STATIC — 'Campus Director' — DO NOT OVERWRITE" }
      ]
    }
  ],

  "form_fields": [

    {
      "field_id": "department",
      "label": "Department",
      "section": "form_info",
      "excel_cell": "B8",
      "merged_range": "B8:D8",
      "write_to": "B8",
      "type": "text",
      "required": true,
      "default": null,
      "validation": { "max_length": 150 },
      "pdf_location": "Meta block — first row, left value cell",
      "example": "Basic Arts and Sciences Department"
    },

    {
      "field_id": "pr_number",
      "label": "PR Number",
      "section": "form_info",
      "excel_cell": "F8",
      "merged_range": "F8:G8",
      "write_to": "F8",
      "type": "text",
      "required": false,
      "default": null,
      "validation": { "max_length": 50 },
      "pdf_location": "Meta block — first row, right value cell",
      "example": "PR-2026-001"
    },

    {
      "field_id": "section_name",
      "label": "Section",
      "section": "form_info",
      "excel_cell": "B9",
      "merged_range": "B9:D9",
      "write_to": "B9",
      "type": "text",
      "required": true,
      "default": null,
      "validation": { "max_length": 150 },
      "pdf_location": "Meta block — second row, left value cell",
      "example": "Chemistry and Physics"
    },

    {
      "field_id": "date",
      "label": "Date",
      "section": "form_info",
      "excel_cell": "F9",
      "merged_range": "F9:G9",
      "write_to": "F9",
      "type": "date",
      "format": "MMM DD, YYYY",
      "required": true,
      "default": null,
      "pdf_location": "Meta block — second row, right value cell",
      "example": "Apr 26, 2026"
    },

    {
      "field_id": "items",
      "label": "Line Items",
      "section": "items_table",
      "type": "repeating_rows",
      "row_start": 12,
      "row_end": 47,
      "max_rows": 36,
      "row_template": 12,
      "notes": "Each element in the items array maps sequentially to one Excel row starting at row 12. Stop at row 42 regardless of how many items exist. Leave unfilled rows blank. Do NOT write placeholder text like 'N/A' or '0' to empty rows.",
      "row_fields": [
        {
          "field_id": "quantity",
          "label": "Quantity",
          "excel_column": "A",
          "write_to_column": "A",
          "type": "integer",
          "required": true,
          "default": null,
          "alignment": "center",
          "validation": { "min": 1, "max": 999999 },
          "example": 4
        },
        {
          "field_id": "unit",
          "label": "Unit",
          "excel_column": "B",
          "write_to_column": "B",
          "type": "text",
          "required": true,
          "default": null,
          "alignment": "center",
          "allowed_values": [
            "bottle", "pcs", "unit", "box", "pack", "set",
            "pair", "ream", "liter", "kg", "g", "ml", "roll", "tube"
          ],
          "validation": { "max_length": 20 },
          "example": "bottle"
        },
        {
          "field_id": "item_description",
          "label": "Item Description",
          "excel_column": "C",
          "merged_range_per_row": "C{row}:D{row}",
          "write_to_column": "C",
          "type": "text",
          "required": true,
          "default": null,
          "alignment": "left",
          "wrap_text": true,
          "validation": { "max_length": 500 },
          "notes": "Write to column C only. The C:D merge displays text across both columns. Combined width is ~58 characters. Long descriptions wrap within the merged cell.",
          "example": "Potassium Hydrogen Phthalate, AR Grade, 500g, branded"
        },
        {
          "field_id": "unit_cost",
          "label": "Unit Cost",
          "excel_column": "E",
          "merged_range_per_row": "E{row}:F{row}",
          "write_to_column": "E",
          "type": "number",
          "format": "#,##0.00",
          "required": true,
          "default": null,
          "alignment": "right",
          "validation": { "min": 0 },
          "notes": "Write numeric value to column E. The E:F merge displays it. Do NOT include a currency symbol — number_format handles display. Store as plain float.",
          "example": 3500.00
        },
        {
          "field_id": "total_cost",
          "label": "Total Cost",
          "excel_column": "G",
          "write_to_column": "G",
          "type": "formula",
          "formula_template": "=A{row}*E{row}",
          "format": "#,##0.00",
          "alignment": "right",
          "readonly": true,
          "required": false,
          "notes": "Template has NO pre-loaded formulas here. Inject =A{row}*E{row} for every populated item row. Never hardcode the computed value — it must remain a formula.",
          "example": 14000.00
        }
      ]
    },

    {
      "field_id": "grand_total",
      "label": "Grand Total",
      "section": "total_row",
      "excel_cell": "F48",
      "merged_range": "F48:G48",
      "write_to": "F48",
      "type": "formula",
      "formula": "=SUM(G12:G47)",
      "format": "#,##0.00",
      "alignment": "right",
      "readonly": true,
      "notes": "Template has NO pre-loaded formula here. After filling all item rows, inject =SUM(G12:G47) into F48. Never hardcode this value.",
      "example": 100000.00
    },

    {
      "field_id": "purpose",
      "label": "Purpose",
      "section": "footer",
      "excel_cell": "C50",
      "merged_range": "C50:G50",
      "write_to": "C50",
      "type": "text",
      "required": true,
      "default": null,
      "wrap_text": true,
      "validation": { "max_length": 500 },
      "pdf_location": "Footer — PURPOSE row value",
      "example": "For CHEM1ET and CHEMENG Laboratory experiments"
    },

    {
      "field_id": "requestor_name",
      "label": "Name of Requestor (Section Head)",
      "section": "footer",
      "excel_cell": "C52",
      "merged_range": null,
      "write_to": "C52",
      "type": "text",
      "required": true,
      "default": null,
      "alignment": "center",
      "validation": { "max_length": 100 },
      "pdf_location": "Footer — NAME OF REQUESTOR row, left name cell",
      "example": "PATRICK JUSTIN ARIADO"
    },

    {
      "field_id": "department_head_name",
      "label": "Name of Department Head",
      "section": "footer",
      "excel_cell": "D52",
      "merged_range": null,
      "write_to": "D52",
      "type": "text",
      "required": false,
      "default": null,
      "alignment": "center",
      "validation": { "max_length": 100 },
      "pdf_location": "Footer — NAME OF REQUESTOR row, middle name cell",
      "notes": "D47 is its own unmerged cell — separate from C47. This correctly maps to the Department Head column visible in the PDF output.",
      "example": "HEHERSON P. RAMOS"
    },

    {
      "field_id": "requestor_designation",
      "label": "Designation of Section Head",
      "section": "footer",
      "excel_cell": "C53",
      "merged_range": null,
      "write_to": "C53",
      "type": "text",
      "required": true,
      "default": "Section Head",
      "alignment": "center",
      "pdf_location": "Footer — DESIGNATION row, left cell",
      "example": "Section Head"
    },

    {
      "field_id": "department_head_designation",
      "label": "Designation of Department Head",
      "section": "footer",
      "excel_cell": "D53",
      "merged_range": null,
      "write_to": "D53",
      "type": "text",
      "required": false,
      "default": "Department Head",
      "alignment": "center",
      "pdf_location": "Footer — DESIGNATION row, middle cell",
      "example": "Department Head"
    },
    {
      "field_id": "unique_code",
      "label": "Unique Code",
      "section": "extra",
      "excel_cell": "G54",
      "write_to": "G54",
      "type": "text",
      "required": false,
      "pdf_location": "Bottom right corner — row 54",
      "example": "ABC-123-XYZ"
    }

  ],

  "readonly_cells": [
    { "range": "A1:G5",   "reason": "Institutional header — TUP branding, address, form code. Never modify." },
    { "range": "A8",      "reason": "'Department:' label" },
    { "range": "E8",      "reason": "'PR NO. :' label" },
    { "range": "A9",      "reason": "'Section:' label" },
    { "range": "E9",      "reason": "'Date:' label" },
    { "range": "A10:G10", "reason": "Full-width horizontal divider line" },
    { "range": "A11:G11", "reason": "Table column headers: Quantity, Unit, Item Description, Unit Cost, Total Cost" },
    { "range": "A48:E48", "reason": "'TOTAL' label — static merged region" },
    { "range": "A49:G49", "reason": "Blank spacer row between TOTAL and footer — leave untouched" },
    { "range": "A50:B50", "reason": "'PURPOSE:' label" },
    { "range": "A51:B51", "reason": "'SIGNATURE:' label" },
    { "range": "C51:D51", "reason": "Physical signature area — must remain blank for wet signature" },
    { "range": "E51:G51", "reason": "'Approved by:' label" },
    { "range": "B52",     "reason": "'NAME OF REQUESTOR:' label" },
    { "range": "E52:G52", "reason": "STATIC — Campus Director name 'Engr. REXMELLE F. DECAPIA, JR. Ph.D.' — DO NOT OVERWRITE." },
    { "range": "A53:B53", "reason": "'DESIGNATION:' label (merged)" },
    { "range": "E53:G53", "reason": "STATIC — 'Campus Director' title — DO NOT OVERWRITE." }
  ],

  "formula_injection": {
    "description": "The template has NO pre-loaded formulas. The agent must inject these after writing data.",
    "formulas": [
      {
        "target": "G{row} for each populated item row (rows 12 to 47)",
        "formula": "=A{row}*E{row}",
        "condition": "Inject only for rows where quantity and unit_cost are populated. Leave blank for empty rows.",
        "example": "G12 → =A12*E12,  G13 → =A13*E13, ..."
      },
      {
        "target": "F48",
        "formula": "=SUM(G12:G47)",
        "condition": "Always inject regardless of how many rows are filled.",
        "example": "F48 → =SUM(G12:G47)"
      }
    ]
  },

  "rules": {
    "preserve_formatting": true,
    "do_not_alter_merged_cells": true,
    "do_not_delete_rows": true,
    "do_not_insert_rows": true,
    "empty_item_rows": "leave_completely_blank",
    "number_format_currency": "#,##0.00",
    "acceptance_criteria": [
      "department and section_name must always be filled",
      "date must be filled and formatted as MMM DD, YYYY (e.g. Apr 26, 2026)",
      "At least one item row (rows 12-47) must be populated",
      "Every populated item row must have: quantity (A), unit (B), item_description (C), unit_cost (E)",
      "G{row} for each populated row must be the formula =A{row}*E{row} — never a hardcoded number",
      "F48 must be the formula =SUM(G12:G47) — never a hardcoded number",
      "Do NOT write to E52:G52 (Campus Director name) or E53:G53 (Campus Director title)",
      "Do NOT write to C51:D51 (physical signature area)",
      "No cell formatting, borders, fonts, or merged regions may be altered",
      "Export using print area A1:G54 in portrait A4 format",
      "Max 36 line items (rows 12-47). If data exceeds 36 items, truncate and log a warning"
    ]
  },

